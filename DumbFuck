                SortOrder = Enum.SortOrder.LayoutOrder
            })
            
            local sectionPadding = Utility:Create("UIPadding", {
                Parent = sectionContent,
                PaddingBottom = UDim.new(0, 15)
            })
            
            local sectionObj = {}
            
            -- Button
            function sectionObj:CreateButton(config)
                config = config or {}
                local buttonText = config.Name or "Button"
                local callback = config.Callback or function() end
                
                local button = Utility:Create("TextButton", {
                    Name = buttonText,
                    Parent = sectionContent,
                    BackgroundColor3 = SiriusLib.Theme.Accent,
                    BackgroundTransparency = 0.2,
                    Size = UDim2.new(1, 0, 0, 40),
                    Font = Enum.Font.GothamBold,
                    Text = buttonText,
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 14
                })
                
                Utility:CreateCorner(button, 8)
                
                button.MouseButton1Click:Connect(function()
                    Utility:Tween(button, {Size = UDim2.new(0.95, 0, 0, 38)}, 0.1, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, function()
                        Utility:Tween(button, {Size = UDim2.new(1, 0, 0, 40)}, 0.2, Enum.EasingStyle.Back)
                    end)
                    
                    local success, err = pcall(callback)
                    if not success then
                        SiriusLib:Notify("Button Error", tostring(err), "Error", 3)
                    end
                end)
                
                button.MouseEnter:Connect(function()
                    Utility:Tween(button, {BackgroundTransparency = 0}, 0.3)
