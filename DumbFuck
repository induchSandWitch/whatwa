            -- Toggle
            function sectionObj:CreateToggle(config)
                config = config or {}
                local toggleName = config.Name or "Toggle"
                local default = config.Default or false
                local flag = config.Flag
                local callback = config.Callback or function() end
                
                local toggleFrame = Utility:Create("Frame", {
                    Name = toggleName,
                    Parent = sectionContent,
                    BackgroundColor3 = SiriusLib.Theme.Primary,
                    BackgroundTransparency = 0.5,
                    Size = UDim2.new(1, 0, 0, 45)
                })
                
                Utility:CreateCorner(toggleFrame, 8)
                
                local label = Utility:Create("TextLabel", {
                    Parent = toggleFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 15, 0, 0),
                    Size = UDim2.new(1, -80, 1, 0),
                    Font = Enum.Font.Gotham,
                    Text = toggleName,
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local toggleButton = Utility:Create("Frame", {
                    Name = "Toggle",
                    Parent = toggleFrame,
                    BackgroundColor3 = SiriusLib.Theme.SubText,
                    Position = UDim2.new(1, -55, 0.5, -12),
                    Size = UDim2.new(0, 44, 0, 24)
                })
                
                Utility:CreateCorner(toggleButton, 12)
                
                local indicator = Utility:Create("Frame", {
                    Name = "Indicator",
                    Parent = toggleButton,
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    Position = UDim2.new(0, 2, 0.5, -10),
                    Size = UDim2.new(0, 20, 0, 20)
                })
                
                Utility:CreateCorner(indicator, 10)
                
                local toggled = default
                
                local function updateToggle()
                    if toggled then
                        Utility:Tween(toggleButton, {BackgroundColor3 = SiriusLib.Theme.Accent}, 0.3)
                        Utility:Tween(indicator, {Position = UDim2.new(1, -22, 0.5, -10)}, 0.3)
                    else
                        Utility:Tween(toggleButton, {BackgroundColor3 = SiriusLib.Theme.SubText}, 0.3)
                        Utility:Tween(indicator, {Position = UDim2.new(0, 2, 0.5, -10)}, 0.3)
                    end
                    
                    if flag then
                        SiriusLib.Flags[flag] = toggled
                    end
                    
                    callback(toggled)
                end
                
                toggleFrame.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        toggled = not toggled
                        updateToggle()
                    end
                end)
                
                updateToggle()
                
                if flag then
                    SiriusLib.Toggles[flag] = {
                        Set = function(value)
                            toggled = value
                            updateToggle()
                        end,
                        Get = function() return toggled end
                    }
                end
                
                return toggleFrame
            end
            
            -- Slider
            function sectionObj:CreateSlider(config)
                config = config or {}
                local sliderName = config.Name or "Slider"
                local min = config.Min or 0
                local max = config.Max or 100
                local default = config.Default or min
                local increment = config.Increment or 1
                local flag = config.Flag
                local callback = config.Callback or function() end
                local suffix = config.Suffix or ""
                
                local sliderFrame = Utility:Create("Frame", {
                    Name = sliderName,
                    Parent = sectionContent,
                    BackgroundColor3 = SiriusLib.Theme.Primary,
                    BackgroundTransparency = 0.5,
                    Size = UDim2.new(1, 0, 0, 60)
                })
                
                Utility:CreateCorner(sliderFrame, 8)
                
                local label = Utility:Create("TextLabel", {
                    Parent = sliderFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 15, 0, 8),
                    Size = UDim2.new(1, -30, 0, 20),
                    Font = Enum.Font.Gotham,
                    Text = sliderName,
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local valueLabel = Utility:Create("TextLabel", {
                    Parent = sliderFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -60, 0, 8),
                    Size = UDim2.new(0, 50, 0, 20),
                    Font = Enum.Font.GothamBold,
                    Text = tostring(default) .. suffix,
                    TextColor3 = SiriusLib.Theme.Accent,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Right
                })
                
                local sliderBar = Utility:Create("Frame", {
                    Name = "Bar",
                    Parent = sliderFrame,
                    BackgroundColor3 = SiriusLib.Theme.Secondary,
                    Position = UDim2.new(0, 15, 0, 40),
                    Size = UDim2.new(1, -30, 0, 8)
                })
                
                Utility:CreateCorner(sliderBar, 4)
                
                local fill = Utility:Create("Frame", {
                    Name = "Fill",
                    Parent = sliderBar,
                    BackgroundColor3 = SiriusLib.Theme.Accent,
                    Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
                })
                
                Utility:CreateCorner(fill, 4)
                
                local knob = Utility:Create("Frame", {
                    Name = "Knob",
                    Parent = sliderBar,
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8),
                    Size = UDim2.new(0, 16, 0, 16),
                    ZIndex = 2
                })
                
                Utility:CreateCorner(knob, 8)
                
                local dragging = false
                local value = default
                
                local function updateSlider(input)
                    local pos = math.clamp((input.Position.X - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
                    value = math.floor((min + (max - min) * pos) / increment) * increment
                    value = math.clamp(value, min, max)
                    
                    Utility:Tween(fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.1)
                    Utility:Tween(knob, {Position = UDim2.new(pos, -8, 0.5, -8)}, 0.1)
                    valueLabel.Text = tostring(value) .. suffix
                    
                    if flag then
                        SiriusLib.Flags[flag] = value
                    end
                    
                    callback(value)
                end
                
                knob.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                    end
                end)
                
                sliderBar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        updateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateSlider(input)
                    end
                end)
                
                if flag then
                    SiriusLib.Sliders[flag] = {
                        Set = function(newValue)
                            value = math.clamp(newValue, min, max)
                            local pos = (value - min) / (max - min)
                            Utility:Tween(fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.3)
                            Utility:Tween(knob, {Position = UDim2.new(pos, -8, 0.5, -8)}, 0.3)
                            valueLabel.Text = tostring(value) .. suffix
                            callback(value)
                        end,
                        Get = function() return value end
                    }
                end
                
                return sliderFrame
            end
            
            -- Dropdown
            function sectionObj:CreateDropdown(config)
                config = config or {}
                local dropdownName = config.Name or "Dropdown"
                local options = config.Options or {}
                default = config.Default or (options[1] or "None")
                local flag = config.Flag
                local callback = config.Callback or function() end
                
                local dropdownFrame = Utility:Create("Frame", {
                    Name = dropdownName,
                    Parent = sectionContent,
                    BackgroundColor3 = SiriusLib.Theme.Primary,
                    BackgroundTransparency = 0.5,
                    Size = UDim2.new(1, 0, 0, 45),
                    ClipsDescendants = true
                })
                
                Utility:CreateCorner(dropdownFrame, 8)
                
                local label = Utility:Create("TextLabel", {
                    Parent = dropdownFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 15, 0, 0),
                    Size = UDim2.new(1, -50, 0, 45),
                    Font = Enum.Font.Gotham,
                    Text = dropdownName,
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local selectedLabel = Utility:Create("TextLabel", {
                    Parent = dropdownFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -150, 0, 0),
                    Size = UDim2.new(0, 120, 0, 45),
                    Font = Enum.Font.GothamBold,
                    Text = default,
                    TextColor3 = SiriusLib.Theme.Accent,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    TextTruncate = Enum.TextTruncate.AtEnd
                })
                
                local arrow = Utility:Create("ImageLabel", {
                    Parent = dropdownFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -30, 0.5, -8),
                    Size = UDim2.new(0, 16, 0, 16),
                    Image = "rbxassetid://3944670656",
                    ImageColor3 = SiriusLib.Theme.SubText
                })
                
                local optionsFrame = Utility:Create("Frame", {
                    Name = "Options",
                    Parent = dropdownFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 50),
                    Size = UDim2.new(1, -20, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Visible = false
                })
                
                local optionsList = Utility:Create("UIListLayout", {
                    Parent = optionsFrame,
                    Padding = UDim.new(0, 5),
                    SortOrder = Enum.SortOrder.LayoutOrder
                })
                
                local selected = default
                local expanded = false
                
                local function toggleDropdown()
                    expanded = not expanded
                    if expanded then
                        optionsFrame.Visible = true
                        Utility:Tween(arrow, {Rotation = 180}, 0.3)
                        Utility:Tween(dropdownFrame, {Size = UDim2.new(1, 0, 0, 50 + math.min(#options * 35, 200))}, 0.3)
                    else
                        Utility:Tween(arrow, {Rotation = 0}, 0.3)
                        Utility:Tween(dropdownFrame, {Size = UDim2.new(1, 0, 0, 45)}, 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, function()
                            optionsFrame.Visible = false
                        end)
                    end
                end
                
                for _, option in ipairs(options) do
                    local optionButton = Utility:Create("TextButton", {
                        Name = option,
                        Parent = optionsFrame,
                        BackgroundColor3 = SiriusLib.Theme.Secondary,
                        BackgroundTransparency = 0.5,
                        Size = UDim2.new(1, 0, 0, 30),
                        Font = Enum.Font.Gotham,
                        Text = option,
                        TextColor3 = SiriusLib.Theme.Text,
                        TextSize = 13
                    })
                    
                    Utility:CreateCorner(optionButton, 6)
                    
                    optionButton.MouseButton1Click:Connect(function()
                        selected = option
                        selectedLabel.Text = selected
                        toggleDropdown()
                        
                        if flag then
                            SiriusLib.Flags[flag] = selected
                        end
                        
                        callback(selected)
                    end)
                    
                    optionButton.MouseEnter:Connect(function()
                        Utility:Tween(optionButton, {BackgroundTransparency = 0.2}, 0.2)
                    end)
                    
                    optionButton.MouseLeave:Connect(function()
                        Utility:Tween(optionButton, {BackgroundTransparency = 0.5}, 0.2)
                    end)
                end
                
                dropdownFrame.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        toggleDropdown()
                    end
                end)
                
                if flag then
                    SiriusLib.Dropdowns[flag] = {
                        Set = function(value)
                            if table.find(options, value) then
                                selected = value
                                selectedLabel.Text = selected
                                callback(selected)
                            end
                        end,
                        Get = function() return selected end,
                        Refresh = function(newOptions)
                            options = newOptions
                            for _, child in pairs(optionsFrame:GetChildren()) do
                                if child:IsA("TextButton") then
                                    child:Destroy()
                                end
                            end
                            -- Rebuild options
                            for _, option in ipairs(options) do
                                -- (Same creation code as above, simplified for brevity)
                            end
                        end
                    }
                end
                
                return dropdownFrame
            end
            
            -- Input
            function sectionObj:CreateInput(config)
                config = config or {}
                local inputName = config.Name or "Input"
                local placeholder = config.Placeholder or "Enter text..."
                local default = config.Default or ""
                local flag = config.Flag
                local callback = config.Callback or function() end
                
                local inputFrame = Utility:Create("Frame", {
                    Name = inputName,
                    Parent = sectionContent,
                    BackgroundColor3 = SiriusLib.Theme.Primary,
                    BackgroundTransparency = 0.5,
                    Size = UDim2.new(1, 0, 0, 80)
                })
                
                Utility:CreateCorner(inputFrame, 8)
                
                local label = Utility:Create("TextLabel", {
                    Parent = inputFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 15, 0, 10),
                    Size = UDim2.new(1, -30, 0, 20),
                    Font = Enum.Font.Gotham,
                    Text = inputName,
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local textBox = Utility:Create("TextBox", {
                    Parent = inputFrame,
                    BackgroundColor3 = SiriusLib.Theme.Secondary,
                    BackgroundTransparency = 0.3,
                    Position = UDim2.new(0, 15, 0, 40),
                    Size = UDim2.new(1, -30, 0, 30),
                    Font = Enum.Font.Gotham,
                    PlaceholderText = placeholder,
                    PlaceholderColor3 = SiriusLib.Theme.SubText,
                    Text = default,
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 13,
                    ClearTextOnFocus = false
                })
                
                Utility:CreateCorner(textBox, 6)
                
                textBox.FocusLost:Connect(function()
                    if flag then
                        SiriusLib.Flags[flag] = textBox.Text
                    end
                    callback(textBox.Text)
                end)
                
                if flag then
                    SiriusLib.Inputs[flag] = {
                        Set = function(text)
                            textBox.Text = text
                            callback(text)
                        end,
                        Get = function() return textBox.Text end
                    }
                end
                
                return inputFrame
            end
            
            -- Keybind
            function sectionObj:CreateKeybind(config)
                config = config or {}
                local keybindName = config.Name or "Keybind"
                local default = config.Default or Enum.KeyCode.Unknown
                local flag = config.Flag
                local callback = config.Callback or function() end
                
                local keybindFrame = Utility:Create("Frame", {
                    Name = keybindName,
                    Parent = sectionContent,
                    BackgroundColor3 = SiriusLib.Theme.Primary,
                    BackgroundTransparency = 0.5,
                    Size = UDim2.new(1, 0, 0, 45)
                })
                
                Utility:CreateCorner(keybindFrame, 8)
                
                local label = Utility:Create("TextLabel", {
                    Parent = keybindFrame,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 15, 0, 0),
                    Size = UDim2.new(1, -100, 1, 0),
                    Font = Enum.Font.Gotham,
                    Text = keybindName,
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local keyButton = Utility:Create("TextButton", {
                    Parent = keybindFrame,
                    BackgroundColor3 = SiriusLib.Theme.Accent,
                    BackgroundTransparency = 0.7,
                    Position = UDim2.new(1, -90, 0.5, -15),
                    Size = UDim2.new(0, 80, 0, 30),
                    Font = Enum.Font.GothamBold,
                    Text = default ~= Enum.KeyCode.Unknown and default.Name or "None",
                    TextColor3 = SiriusLib.Theme.Text,
                    TextSize = 12
                })
                
                Utility:CreateCorner(keyButton, 6)
                
                local listening = false
                local currentKey = default
                
                keyButton.MouseButton1Click:Connect(function()
                    listening = true
                    keyButton.Text = "..."
                    
                    local connection
                    connection = UserInputService.InputBegan:Connect(function(input)
                        if listening then
                            if input.KeyCode ~= Enum.KeyCode.Unknown then
                                currentKey = input.KeyCode
                                keyButton.Text = currentKey.Name
                                listening = false
                                
                                if flag then
                                    SiriusLib.Flags[flag] = currentKey
                                end
                                
                                if flag then
                                    SiriusLib.Keybinds[flag] = {
                                        Key = currentKey,
                                        Callback = callback
                                    }
                                end
                            end
                            connection:Disconnect()
                        end
                    end)
                end)
                
                -- Global keybind handler
                UserInputService.InputBegan:Connect(function(input)
                    if input.KeyCode == currentKey and not listening then
                        callback()
                    end
                end)
                
                if flag then
                    SiriusLib.Keybinds[flag] = {
                        Key = currentKey,
                        Callback = callback,
                        Set = function(key)
                            currentKey = key
                            keyButton.Text = currentKey.Name
                        end
                    }
                end
                
                return keybindFrame
            end
            
            -- Label
            function sectionObj:CreateLabel(text)
                local label = Utility:Create("TextLabel", {
                    Parent = sectionContent,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 25),
                    Font = Enum.Font.Gotham,
                    Text = text,
                    TextColor3 = SiriusLib.Theme.SubText,
                    TextSize = 13,
                    TextWrapped = true,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                return label
            end
            
            return sectionObj
        end
        
        tabs[name] = {
            Button = tabButton,
            Content = tabContent,
            Section = tab.Section
        }
        
        -- Auto-select first tab
        if not activeTab then
            switchTab(name)
        end
        
        return tab
    end
    
    -- Window Controls
    local minimized = false
    local closed = false
    
    minimizeButton.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            Utility:Tween(mainFrame, {Size = UDim2.new(0, 750, 0, 50)}, 0.5, Enum.EasingStyle.Back)
            tabContainer.Visible = false
            contentContainer.Visible = false
        else
            Utility:Tween(mainFrame, {Size = UDim2.new(0, 750, 0, 450)}, 0.5, Enum.EasingStyle.Back)
            task.delay(0.3, function()
                tabContainer.Visible = true
                contentContainer.Visible = true
            end)
        end
    end)
    
    closeButton.MouseButton1Click:Connect(function()
        closed = true
        Utility:Tween(mainFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In, function()
            mainGui:Destroy()
        end)
    end)
    
    -- Script Search Button
    searchButton.MouseButton1Click:Connect(function()
        SiriusLib:OpenScriptSearch()
    end)
    
    searchButton.MouseEnter:Connect(function()
        Utility:Tween(searchButton, {BackgroundTransparency = 0.4}, 0.3)
    end)
    
    searchButton.MouseLeave:Connect(function()
        Utility:Tween(searchButton, {BackgroundTransparency = 0.8}, 0.3)
    end)
    
    -- Toggle Keybind
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == keybind and not closed then
            mainFrame.Visible = not mainFrame.Visible
            if mainFrame.Visible and SiriusLib.FirstLoad then
                SiriusLib.FirstLoad = false
                Utility:Tween(mainFrame, {Size = UDim2.new(0, 750, 0, 450)}, 0.5, Enum.EasingStyle.Back)
            end
        end
    end)
    
    -- Initial Animation
    mainFrame.Visible = true
    mainFrame.Size = UDim2.new(0, 0, 0, 0)
    Utility:Tween(mainFrame, {Size = UDim2.new(0, 750, 0, 450)}, 0.6, Enum.EasingStyle.Back)
    
    table.insert(SiriusLib.Windows, window)
    return window
end

--// Theme Customization
function SiriusLib:SetTheme(themeTable)
    for key, value in pairs(themeTable) do
        if SiriusLib.Theme[key] then
            SiriusLib.Theme[key] = value
        end
    end
end

--// Return Library
return SiriusLib
