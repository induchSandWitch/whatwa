        local title = Utility:Create("TextLabel", {
            Parent = button,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 15, 0, 10),
            Size = UDim2.new(1, -30, 0, 25),
            Font = Enum.Font.GothamBold,
            Text = data.title or "Unknown Script",
            TextColor3 = SiriusLib.Theme.Text,
            TextSize = 16,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextTruncate = Enum.TextTruncate.AtEnd
        })
        
        local author = Utility:Create("TextLabel", {
            Parent = button,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 15, 0, 35),
            Size = UDim2.new(1, -30, 0, 20),
            Font = Enum.Font.Gotham,
            Text = "by " .. (data.owner and data.owner.username or "Unknown"),
            TextColor3 = SiriusLib.Theme.SubText,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left
        })
        
        local executeButton = Utility:Create("TextButton", {
            Parent = button,
            BackgroundColor3 = SiriusLib.Theme.Accent,
            Position = UDim2.new(1, -100, 0.5, -15),
            Size = UDim2.new(0, 90, 0, 30),
            Font = Enum.Font.GothamBold,
            Text = "Execute",
            TextColor3 = SiriusLib.Theme.Text,
            TextSize = 14
        })
        
        Utility:CreateCorner(executeButton, 6)
        
        local patchedBadge = data.isPatched and Utility:Create("Frame", {
            Parent = button,
            BackgroundColor3 = SiriusLib.Theme.Error,
            Position = UDim2.new(0, 15, 1, -25),
            Size = UDim2.new(0, 80, 0, 20)
        }) or nil
        
        if patchedBadge then
            Utility:CreateCorner(patchedBadge, 4)
            Utility:Create("TextLabel", {
                Parent = patchedBadge,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Font = Enum.Font.GothamBold,
                Text = "PATCHED",
                TextColor3 = SiriusLib.Theme.Text,
                TextSize = 12
            })
        end
        
        -- Hover effects
        button.MouseEnter:Connect(function()
            Utility:Tween(button, {BackgroundTransparency = 0.3}, 0.3)
        end)
        
        button.MouseLeave:Connect(function()
            Utility:Tween(button, {BackgroundTransparency = 0.5}, 0.3)
        end)
        
        executeButton.MouseButton1Click:Connect(function()
            if data.script and not data.isPatched then
                SiriusLib:Notify("Executing Script", "Running " .. data.title, "Info", 3)
                local success, err = pcall(function()
                    loadstring(data.script)()
                end)
                if not success then
                    SiriusLib:Notify("Execution Failed", tostring(err), "Error", 5)
                end
            elseif data.isPatched then
                SiriusLib:Notify("Script Patched", "This script is currently patched and cannot be executed.", "Warning", 3)
            end
        end)
        
        return button
    end
    
    local function search(query)
        -- Clear previous results
        for _, child in pairs(resultsFrame:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        if #query < 2 then return end
        
        -- Loading indicator
        local loading = Utility:Create("TextLabel", {
            Parent = resultsFrame,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 50),
            Font = Enum.Font.Gotham,
            Text = "Searching...",
            TextColor3 = SiriusLib.Theme.SubText,
            TextSize = 16
        })
        
        -- API Call
        task.spawn(function()
            local success, result = pcall(function()
                local response = request({
                    Url = "https://scriptblox.com/api/script/search?q=" .. HttpService:UrlEncode(query) .. "&mode=free&max=20&page=1",
                    Method = "GET"
                })
                return HttpService:JSONDecode(response.Body)
            end)
            
            loading:Destroy()
            
            if success and result and result.result then
                if #result.result.scripts == 0 then
                    Utility:Create("TextLabel", {
                        Parent = resultsFrame,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 50),
                        Font = Enum.Font.Gotham,
                        Text = "No scripts found",
                        TextColor3 = SiriusLib.Theme.SubText,
                        TextSize = 16
                    })
                    return
                end
                
                for _, scriptData in pairs(result.result.scripts) do
                    createScriptButton(scriptData)
                end
            else
                Utility:Create("TextLabel", {
                    Parent = resultsFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 50),
                    Font = Enum.Font.Gotham,
                    Text = "Failed to search scripts",
                    TextColor3 = SiriusLib.Theme.Error,
                    TextSize = 16
                })
            end
        end)
    end
    
    searchBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            search(searchBox.Text)
        end
    end)
    
    closeButton.MouseButton1Click:Connect(function()
        Utility:Tween(mainFrame, {Size = UDim2.new(0, 600, 0, 0)}, 0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In, function()
            searchGui:Destroy()
        end)
    end)
    
    -- Auto focus
    searchBox:CaptureFocus()
    
    return searchGui
end

