        local function update(input)
            local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            local value = math.floor(slider.Min + (pos * (slider.Max - slider.Min)))
            
            slider.Value = value
            valueLabel.Text = tostring(value)
            
            Utility:Tween(fill, Theme.Animation.Fast, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
            Utility:Tween(knob, Theme.Animation.Fast, {Position = UDim2.new(pos, -6, 0.5, -6)}):Play()
            
            if data.Callback then
                data.Callback(value)
            end
        end
        
        bar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                update(input)
            end
        end)
        
        Services.UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                update(input)
            end
        end)
        
        Services.UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        slider.Set = function(self, value)
            value = math.clamp(value, slider.Min, slider.Max)
            slider.Value = value
            valueLabel.Text = tostring(value)
            
            local pos = (value - slider.Min) / (slider.Max - slider.Min)
            Utility:Tween(fill, Theme.Animation.Normal, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
            Utility:Tween(knob, Theme.Animation.Normal, {Position = UDim2.new(pos, -6, 0.5, -6)}):Play()
            
            if data.Callback then
                data.Callback(value)
            end
        end
        
        return slider
    end
    
