            Position = UDim2.new(0, 15, 0, 0),
            Size = UDim2.new(1, -80, 1, 0),
            Font = Enum.Font.GothamBold,
            Text = data.Title or "Color Picker",
            TextColor3 = Theme.Colors.Text,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left
        })
        
        local colorBtn = Utility:Create("TextButton", {
            Parent = container,
            BackgroundColor3 = picker.Value,
            BorderSizePixel = 0,
            Position = UDim2.new(1, -55, 0.5, -12),
            Size = UDim2.new(0, 40, 0, 24),
            Text = ""
        })
        
        local colorCorner = Utility:Create("UICorner", {
            Parent = colorBtn,
            CornerRadius = UDim.new(0, 4)
        })
        
        colorBtn.MouseButton1Click:Connect(function()
            -- Simple color picker implementation
            local r = math.random(0, 255)
            local g = math.random(0, 255)
            local b = math.random(0, 255)
            picker.Value = Color3.fromRGB(r, g, b)
            colorBtn.BackgroundColor3 = picker.Value
            
            if data.Callback then
                data.Callback(picker.Value)
            end
        end)
        
        picker.Set = function(self, color)
            picker.Value = color
            colorBtn.BackgroundColor3 = color
        end
        
        return picker
    end
    
    table.insert(self.Tabs, tab)
    
    -- Auto-select first tab
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    
    return tab
end

function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end
    
    -- Deselect current
    if self.ActiveTab then
        Utility:Tween(self.ActiveTab.Button, Theme.Animation.Fast, {
            BackgroundTransparency = 1
        }):Play()
        Utility:Tween(self.ActiveTab.Button:FindFirstChildOfClass("ImageLabel"), Theme.Animation.Fast, {
            ImageColor3 = Theme.Colors.TextDark
        }):Play()
        Utility:Tween(self.ActiveTab.Button:FindFirstChildOfClass("TextLabel"), Theme.Animation.Fast, {
            TextColor3 = Theme.Colors.TextDark
        }):Play()
        self.ActiveTab.Content.Visible = false
    end
    
    -- Select new
    self.ActiveTab = tab
    Utility:Tween(tab.Button, Theme.Animation.Fast, {
        BackgroundTransparency = 0.5
    }):Play()
    
    local icon = tab.Button:FindFirstChildOfClass("ImageLabel")
    if icon then
        Utility:Tween(icon, Theme.Animation.Fast, {
            ImageColor3 = tab.Color
        }):Play()
    end
    
    local label = tab.Button:FindFirstChildOfClass("TextLabel")
    if label then
        Utility:Tween(label, Theme.Animation.Fast, {
            TextColor3 = Theme.Colors.Text
        }):Play()
    end
    
    tab.Content.Visible = true
end

function Window:Notify(data)
    return self.Notifications:Notify(data)
end

function Window:Close()
    Utility:Tween(self.Main, Theme.Animation.Normal, {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0)
    }):Play()
    
    task.wait(0.4)
    self.Gui:Destroy()
end

function Window:Minimize()
    self.Minimized = not self.Minimized
    
    if self.Minimized then
        Utility:Tween(self.Main, Theme.Animation.Normal, {
            Size = UDim2.new(0, self.Size.X.Offset, 0, 50)
        }):Play()
    else
        Utility:Tween(self.Main, Theme.Animation.Normal, {
            Size = self.Size
        }):Play()
    end
end

-- Sirius Library Interface
function Sirius:Init(data)
    return Window.new(data)
end

function Sirius:Notify(data)
    -- Create temporary notification system if no window exists
    local notifGui = Utility:Create("ScreenGui", {
        Name = "SiriusNotifications",
        Parent = Services.CoreGui
    })
    
    local notifSystem = NotificationSystem.new(notifGui)
    return notifSystem:Notify(data)
end

-- Return the library
return Sirius
