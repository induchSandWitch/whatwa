    self.Container.Visible = true
    
    self.Container.Size = UDim2.new(0, 480, 0, 23)
    self.Container.Position = UDim2.new(0.5, -240, 0.5, 0)
    
    Utility:Tween(self.Container, Theme.Animation.Slow, {
        Size = UDim2.new(0, 580, 0, 43),
        Position = UDim2.new(0.5, -290, 0.5, -20)
    }):Play()
    
    task.wait(0.3)
    self.SearchBox:CaptureFocus()
end

function ScriptSearch:Close()
    if not self.Visible then return end
    
    Utility:Tween(self.Container, Theme.Animation.Normal, {
        Size = UDim2.new(0, 520, 0, 0)
    }):Play()
    
    -- Clear results
    for _, child in pairs(self.ResultsFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    self.ResultsFrame.Visible = false
    self.SearchBox.Text = ""
    
    task.wait(0.4)
    self.Container.Visible = false
    self.Visible = false
end

function ScriptSearch:Search(query)
    self.ResultsFrame.Visible = true
    
    -- Clear previous results
    for _, child in pairs(self.ResultsFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    -- Loading indicator
    local loading = Utility:Create("TextLabel", {
        Parent = self.ResultsFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 40),
        Font = Enum.Font.Gotham,
        Text = "Searching...",
        TextColor3 = Theme.Colors.TextDark,
        TextSize = 14
    })
    
    -- Expand container
    Utility:Tween(self.Container, Theme.Animation.Slow, {
        Size = UDim2.new(0, 580, 0, 529)
    }):Play()
    
    Utility:Tween(self.Icon, Theme.Animation.Fast, {
        Position = UDim2.new(0, 30, 0, 30)
    }):Play()
    
    Utility:Tween(self.SearchBox, Theme.Animation.Fast, {
        Position = UDim2.new(0, 60, 0, 0)
    }):Play()
    
    -- API Call
    task.spawn(function()
        local success, result = pcall(function()
            local url = "https://scriptblox.com/api/script/search?q=" .. 
                       Services.HttpService:UrlEncode(query) .. 
                       "&mode=free&max=20&page=1"
            
            local response = request({
                Url = url,
                Method = "GET"
            })
            
            return Services.HttpService:JSONDecode(response.Body)
        end)
        
        loading:Destroy()
        
        if success and result and result.result then
            if #result.result.scripts == 0 then
                self:ShowNoResults()
            else
                for _, scriptData in ipairs(result.result.scripts) do
                    self:CreateScriptCard(scriptData)
                end
            end
        else
            self:ShowError()
        end
        
        self.ResultsFrame.CanvasSize = UDim2.new(0, 0, 0, 
            self.ResultsFrame.UIListLayout.AbsoluteContentSize.Y)
    end)
end

