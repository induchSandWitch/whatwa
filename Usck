    local ico = Utility:Create("ImageLabel", {Parent = tab.Button, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,12), Size = UDim2.new(0,20,0,20), Image = data.Icon or "rbxassetid://7733964640", ImageColor3 = Theme.Colors.TextSoft})
    local label = Utility:Create("TextLabel", {Parent = tab.Button, BackgroundTransparency = 1, Position = UDim2.new(0,44,0,0), Size = UDim2.new(1,-60,1,0), Font = Enum.Font.Gotham, Text = tab.Name, TextColor3 = Theme.Colors.TextSoft, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left})
    local content = Utility:Create("ScrollingFrame", {Parent = self.Content, BackgroundTransparency = 1, BorderSizePixel = 0, Size = UDim2.new(1,0,1,0), CanvasSize = UDim2.new(0,0,0,0), ScrollBarThickness = 6, ScrollBarImageColor3 = tab.Color, Visible = false})
    local layout = Utility:Create("UIListLayout", {Parent = content, Padding = UDim.new(0,12), SortOrder = Enum.SortOrder.LayoutOrder, HorizontalAlignment = Enum.HorizontalAlignment.Center})
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() content.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 20) end)
    tab.Content = content
    tab.Button.MouseButton1Click:Connect(function() self:SelectTab(tab) end)
    tab.Button.MouseEnter:Connect(function() Utility:Tween(tab.Button, Theme.Tween.Fast, {BackgroundTransparency = 0}) end)
    tab.Button.MouseLeave:Connect(function() if self.ActiveTab ~= tab then Utility:Tween(tab.Button, Theme.Tween.Fast, {BackgroundTransparency = 0.03}) end end)
    function tab:AddSection(title)
        local lbl = Utility:Create("TextLabel", {Parent = self.Content, BackgroundTransparency = 1, Size = UDim2.new(1,-40,0,28), Font = Enum.Font.GothamBold, Text = title, TextColor3 = Theme.Colors.Text, TextSize = 16, TextXAlignment = Enum.TextXAlignment.Left})
        local bar = Utility:Create("Frame", {Parent = self.Content, BackgroundColor3 = tab.Color, Size = UDim2.new(1,-40,0,2)})
        local corner = Utility:Create("UICorner", {Parent = bar, CornerRadius = UDim.new(0,4)})
        return lbl
    end
    function tab:AddButton(data)
        data = data or {}
        local btn = Utility:Create("TextButton", {Parent = self.Content, BackgroundColor3 = Color3.fromRGB(44,46,54), BackgroundTransparency = 0.02, Size = UDim2.new(1,-40,0,44), Font = Enum.Font.GothamBold, Text = data.Title or "Button", TextColor3 = Theme.Colors.Text, TextSize = 14, AutoButtonColor = false})
        local corner = Utility:Create("UICorner", {Parent = btn, CornerRadius = UDim.new(0,8)})
        local ripple = Utility:Create("Frame", {Parent = btn, BackgroundColor3 = tab.Color, Size = UDim2.new(0,0,0,0), AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(0.5,0,0.5,0), BackgroundTransparency = 1, ZIndex = 2})
        local rippleCorner = Utility:Create("UICorner", {Parent = ripple, CornerRadius = UDim.new(1,0)})
        local function animateRipple()
            ripple.Size = UDim2.new(0,0,0,0)
            ripple.BackgroundTransparency = 0.18
