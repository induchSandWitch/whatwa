        local holder = Utility:Create("Frame", {Parent = self.Content, BackgroundColor3 = Color3.fromRGB(28,30,36), Size = UDim2.new(1,-40,0,56), BorderSizePixel = 0})
        local corner = Utility:Create("UICorner", {Parent = holder, CornerRadius = UDim.new(0,8)})
