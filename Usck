    local icon = Utility:Create("ImageLabel", {Parent = frame, BackgroundTransparency = 1, Position = UDim2.new(0,12,0,12), Size = UDim2.new(0,36,0,36), Image = "rbxassetid://7733921626", ImageColor3 = Theme.Colors.AccentA})
    local titleLbl = Utility:Create("TextLabel", {Parent = frame, BackgroundTransparency = 1, Position = UDim2.new(0,60,0,10), Size = UDim2.new(1,-72,0,20), Font = Enum.Font.GothamBold, Text = title, TextColor3 = Theme.Colors.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, TextScaled = false})
    local descLbl = Utility:Create("TextLabel", {Parent = frame, BackgroundTransparency = 1, Position = UDim2.new(0,60,0,30), Size = UDim2.new(1,-72,0,36), Font = Enum.Font.Gotham, Text = desc, TextColor3 = Theme.Colors.TextSoft, TextSize = 12, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left})
    local glow = Utility:Create("UIStroke", {Parent = titleLbl, Color = Theme.Colors.AccentA, Thickness = 2, Transparency = 0.9})
    frame.Size = UDim2.new(0,320,0,0)
    Utility:Tween(frame, Theme.Tween.Smooth, {Size = UDim2.new(0,320,0,84)})
    task.delay(dur, function()
        Utility:Tween(frame, Theme.Tween.Fast, {Size = UDim2.new(0,320,0,0), BackgroundTransparency = 1})
        task.wait(0.25)
        frame:Destroy()
    end)
    return frame
end
