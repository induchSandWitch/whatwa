        local switch = Utility:Create("Frame", {Parent = holder, BackgroundColor3 = Theme.Colors.BG, Position = UDim2.new(1,-84,0.5,-12), Size = UDim2.new(0,48,0,24)})
        local switchCorner = Utility:Create("UICorner", {Parent = switch, CornerRadius = UDim.new(1,0)})
        local knob = Utility:Create("Frame", {Parent = switch, BackgroundColor3 = Color3.fromRGB(245,245,245), Size = UDim2.new(0,18,0,18), Position = UDim2.new(0,6,0.5,-9)})
        local knobCorner = Utility:Create("UICorner", {Parent = knob, CornerRadius = UDim.new(1,0)})
        local state = data.Default or false
        local function setState(v)
            state = v
            if state then
                Utility:Tween(knob, Theme.Tween.Fast, {Position = UDim2.new(1,-24,0.5,-9)})
                Utility:Tween(switch, Theme.Tween.Fast, {BackgroundColor3 = tab.Color})
            else
                Utility:Tween(knob, Theme.Tween.Fast, {Position = UDim2.new(0,6,0.5,-9)})
                Utility:Tween(switch, Theme.Tween.Fast, {BackgroundColor3 = Theme.Colors.BG})
            end
            if data.Callback then task.spawn(function() data.Callback(state) end) end
        end
        holder.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then setState(not state) end end)
        setState(state)
        return {Set = function(_,v) setState(v) end, Get = function() return state end}
    end
    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 then self:SelectTab(tab) end
    return tab
end
function Window:SelectTab(tab)
    if self.ActiveTab then
        Utility:Tween(self.ActiveTab.Button, Theme.Tween.Fast, {BackgroundTransparency = 0.03})
        local oldIcon = self.ActiveTab.Button:FindFirstChildOfClass("ImageLabel")
        if oldIcon then Utility:Tween(oldIcon, Theme.Tween.Fast, {ImageColor3 = Theme.Colors.TextSoft}) end
        self.ActiveTab.Content.Visible = false
    end
    self.ActiveTab = tab
    Utility:Tween(tab.Button, Theme.Tween.Fast, {BackgroundTransparency = 0})
    local icon = tab.Button:FindFirstChildOfClass("ImageLabel")
    if icon then Utility:Tween(icon, Theme.Tween.Fast, {ImageColor3 = tab.Color}) end
    local lbl = tab.Button:FindFirstChildOfClass("TextLabel")
    if lbl then Utility:Tween(lbl, Theme.Tween.Fast, {TextColor3 = Theme.Colors.Text}) end
    tab.Content.Visible = true
end
