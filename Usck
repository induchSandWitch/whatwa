        task.spawn(function()
            while anim and cont.Parent do
                Utility:Tween(glow, Theme.Tween.Smooth, {Transparency = 0.2})
                task.wait(1.6)
                Utility:Tween(glow, Theme.Tween.Smooth, {Transparency = 0.85})
                task.wait(1.6)
            end
        end)
        return cont
    end
    function tab:AddToggle(data)
