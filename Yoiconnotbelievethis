        toggleBtn.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            U.Tween(f, T.Normal, { Size = UDim2.new(1,-20,0, isOpen and 200 or closedH) })
        end)

        function obj:Set(c) obj.Value = c; preview.BackgroundColor3 = c end
        return obj
    end

    -- Auto-select if first
    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 then self:_SelectTab(tab) end

    return tab
end

function Window:_SelectTab(tab)
    if self.ActiveTab == tab then return end

    if self.ActiveTab then
        local aBtn = self.ActiveTab.Btn
        U.Tween(aBtn, T.Fast, { BackgroundTransparency = 1 })
        self.ActiveTab.BtnBar.BackgroundTransparency = 1
        self.ActiveTab.Scroll.Visible = false
    end

    self.ActiveTab = tab
    U.Tween(tab.Btn, T.Fast, { BackgroundTransparency = 0.55 })
    U.Tween(tab.BtnBar, T.Spring, { BackgroundTransparency = 0 })
    tab.Scroll.Visible = true
end

function Window:Notify(data)
    self.Notif:Push(data)
end

function Window:Minimize()
    self.Minimized = not self.Minimized
    if self.Minimized then
        U.Tween(self.Main, T.Normal, { Size = UDim2.new(0, self.Size.X.Offset, 0, 52) })
    else
        U.Tween(self.Main, T.Spring, { Size = self.Size })
    end
end

function Window:Close()
    U.Tween(self.Main, T.Normal, {
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1
    })
    task.delay(0.35, function()
        self.Gui:Destroy()
    end)
end

-- ─────────────────────────────────────────────────────────
-- PUBLIC API
-- ─────────────────────────────────────────────────────────
function Sirius:CreateWindow(cfg)
    return Window.new(cfg)
end

-- Standalone notify
function Sirius:Notify(data)
    local g = U.New("ScreenGui", { Name = "SiriusNotif_tmp", Parent = CoreGui })
    local n = Notif.new(g)
    n:Push(data)
    task.delay((data.Duration or 5) + 1, function() g:Destroy() end)
end

return Sirius

