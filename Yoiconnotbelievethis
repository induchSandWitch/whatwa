-- ─────────────────────────────────────────────────────────
-- UTILITY
-- ─────────────────────────────────────────────────────────
local U = {}

function U.New(class, props, children)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            pcall(function() obj[k] = v end)
        end
    end
    for _, child in ipairs(children or {}) do
        child.Parent = obj
    end
    if props and props.Parent then obj.Parent = props.Parent end
    return obj
end

function U.Tween(inst, info, props)
    local t = TweenService:Create(inst, info, props)
    t:Play()
    return t
end

function U.Corner(parent, radius)
    return U.New("UICorner", { CornerRadius = UDim.new(0, radius or 8), Parent = parent })
end

function U.Stroke(parent, color, thickness, trans)
    return U.New("UIStroke", {
        Color = color or T.Accent,
        Thickness = thickness or 1.5,
        Transparency = trans or 0,
        Parent = parent,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    })
end

function U.Gradient(parent, c0, c1, rot)
    return U.New("UIGradient", {
        Color = ColorSequence.new(c0, c1),
        Rotation = rot or 90,
        Parent = parent
    })
end

function U.Shadow(parent, size, trans)
    local s = U.New("ImageLabel", {
        Name = "__Shadow",
        BackgroundTransparency = 1,
        Position = UDim2.new(0, -size, 0, -size),
        Size = UDim2.new(1, size*2, 1, size*2),
        Image = "rbxassetid://6015897843",
        ImageColor3 = Color3.new(0,0,0),
        ImageTransparency = trans or 0.6,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49,49,450,450),
        ZIndex = parent.ZIndex - 1,
        Parent = parent
    })
    return s
end

function U.Draggable(frame, handle)
    handle = handle or frame
    local dragging, start, startPos
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            start = i.Position
            startPos = frame.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local d = i.Position - start
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

-- Ripple effect on a button
function U.Ripple(btn, color)
    color = color or Color3.new(1,1,1)
    local mouse = UserInputService:GetMouseLocation()
    local rel = mouse - Vector2.new(btn.AbsolutePosition.X, btn.AbsolutePosition.Y)
    local ripple = U.New("Frame", {
        Name = "Ripple",
        BackgroundColor3 = color,
        BackgroundTransparency = 0.7,
        Position = UDim2.new(0, rel.X - 5, 0, rel.Y - 5),
        Size = UDim2.new(0, 10, 0, 10),
        ZIndex = btn.ZIndex + 5,
        Parent = btn
    })
    U.Corner(ripple, 100)
    local maxSize = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2
    U.Tween(ripple, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        Position = UDim2.new(0, rel.X - maxSize/2, 0, rel.Y - maxSize/2),
        BackgroundTransparency = 1
    })
    task.delay(0.5, function() ripple:Destroy() end)
end

-- Glow pulse on a frame
function U.GlowPulse(frame, stroke, onColor, offColor)
    local on = true
    RunService.Heartbeat:Connect(function()
        -- handled by tween loops
    end)
    local function loop()
        U.Tween(stroke, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Color = on and onColor or offColor,
            Transparency = on and 0 or 0.6
        })
        on = not on
        task.delay(1.2, loop)
    end
    loop()
end

