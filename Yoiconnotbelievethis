            Text = data.Title or "Toggle",
            TextColor3 = T.TextW,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = f
        })
        if data.Desc then
            U.New("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 14, 0, 32),
                Size = UDim2.new(1, -80, 0, 16),
                Font = Enum.Font.Gotham,
                Text = data.Desc,
                TextColor3 = T.TextD,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = f
            })
        end

        local track = U.New("Frame", {
            BackgroundColor3 = T.BG3,
            BorderSizePixel = 0,
            AnchorPoint = Vector2.new(1, 0.5),
            Position = UDim2.new(1, -14, 0.5, 0),
            Size = UDim2.new(0, 46, 0, 26),
            Parent = f
        })
        U.Corner(track, 100)

        local knob = U.New("Frame", {
            BackgroundColor3 = T.TextD,
            BorderSizePixel = 0,
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, state and 22 or 4, 0.5, 0),
            Size = UDim2.new(0, 18, 0, 18),
            Parent = track
        })
        U.Corner(knob, 100)

        if state then
            track.BackgroundColor3 = tab.Color
            knob.BackgroundColor3 = Color3.new(1,1,1)
            knob.Position = UDim2.new(0, 24, 0.5, 0)
        end

        local function toggle()
            state = not state
            U.Tween(track, T.Normal, { BackgroundColor3 = state and tab.Color or T.BG3 })
            U.Tween(knob, T.Spring, {
                Position = UDim2.new(0, state and 24 or 4, 0.5, 0),
                BackgroundColor3 = state and Color3.new(1,1,1) or T.TextD
            })
            if state then U.Ripple(f, tab.Color) end
            if data.Callback then data.Callback(state) end
        end

        local btn = U.New("TextButton", {
            BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0), Text = "", ZIndex = f.ZIndex+2, Parent = f
        })
        btn.MouseButton1Click:Connect(toggle)

        local obj = {}
        function obj:Set(v)
            if v ~= state then toggle() end
        end
        function obj:Get() return state end
        return obj
    end

    -- ── SLIDER ──────────────────────────────────────────
    function tab:AddSlider(data)
        data = data or {}
        local obj = {}
        obj.Min = data.Min or 0
        obj.Max = data.Max or 100
        obj.Value = math.clamp(data.Default or obj.Min, obj.Min, obj.Max)

        local f = Elem(62)

        local titleRow = U.New("Frame", {
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 14, 0, 10),
            Size = UDim2.new(1, -28, 0, 20),
            Parent = f
        })
        U.New("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -60, 1, 0),
            Font = Enum.Font.GothamBold,
            Text = data.Title or "Slider",
            TextColor3 = T.TextW, TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = titleRow
        })
        local valLbl = U.New("TextLabel", {
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(1, 0),
            Position = UDim2.new(1, 0, 0, 0),
            Size = UDim2.new(0, 55, 1, 0),
            Font = Enum.Font.GothamBold,
            Text = tostring(obj.Value),
            TextColor3 = tab.Color, TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Right,
            Parent = titleRow
        })

        local track = U.New("Frame", {
            BackgroundColor3 = T.BG3,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 14, 0, 38),
            Size = UDim2.new(1, -28, 0, 8),
            Parent = f
        })
        U.Corner(track, 100)

        local pct = (obj.Value - obj.Min) / (obj.Max - obj.Min)

        local fill = U.New("Frame", {
            BackgroundColor3 = tab.Color,
            BorderSizePixel = 0,
            Size = UDim2.new(pct, 0, 1, 0),
            Parent = track
        })
        U.Corner(fill, 100)

        local knob = U.New("Frame", {
            BackgroundColor3 = Color3.new(1,1,1),
            BorderSizePixel = 0,
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(pct, 0, 0.5, 0),
            Size = UDim2.new(0, 14, 0, 14),
            ZIndex = f.ZIndex + 2,
            Parent = track
        })
        U.Corner(knob, 100)
        U.Stroke(knob, tab.Color, 2, 0.2)

        local dragging = false

        local function updateFromX(absX)
            local rel = math.clamp((absX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local v = obj.Min + math.round(rel * (obj.Max - obj.Min))
            obj.Value = v
            valLbl.Text = tostring(v)
            U.Tween(fill, T.Fast, { Size = UDim2.new(rel, 0, 1, 0) })
            U.Tween(knob, T.Fast, { Position = UDim2.new(rel, 0, 0.5, 0) })
            if data.Callback then data.Callback(v) end
        end

        track.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                updateFromX(i.Position.X)
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
                updateFromX(i.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)

        function obj:Set(v)
            v = math.clamp(v, self.Min, self.Max)
            self.Value = v
            valLbl.Text = tostring(v)
            local rel = (v - self.Min)/(self.Max - self.Min)
            U.Tween(fill, T.Normal, { Size = UDim2.new(rel, 0, 1, 0) })
            U.Tween(knob, T.Normal, { Position = UDim2.new(rel, 0, 0.5, 0) })
        end
        return obj
    end

