function Notif:Push(data)
    local title    = data.Title    or "Sirius"
    local desc     = data.Desc     or ""
    local duration = data.Duration or 5
    local kind     = data.Type     or "Info"  -- Info | Success | Warning | Error

    local kindColor = {
        Info    = T.Accent,
        Success = T.Green,
        Warning = T.Yellow,
        Error   = T.Red,
    }
    local col = kindColor[kind] or T.Accent

    -- Card
    local card = U.New("Frame", {
        Name = "Notif",
        BackgroundColor3 = T.BG2,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
        ClipsDescendants = true,
        Parent = self.Container
    })
    U.Corner(card, 10)
    local stroke = U.Stroke(card, col, 1.5, 0.3)

    -- Side accent bar
    U.New("Frame", {
        BackgroundColor3 = col,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 3, 1, 0),
        Parent = card
    })

    -- Glow bg
    local gBg = U.New("Frame", {
        BackgroundColor3 = col,
        BackgroundTransparency = 0.88,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        Parent = card
    })

    local titleLbl = U.New("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 18, 0, 10),
        Size = UDim2.new(1, -50, 0, 20),
        Font = Enum.Font.GothamBold,
        Text = title,
        TextColor3 = T.TextW,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = card
    })

    local descLbl = U.New("TextLabel", {
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 18, 0, 32),
        Size = UDim2.new(1, -50, 0, 38),
        Font = Enum.Font.Gotham,
        Text = desc,
        TextColor3 = T.TextD,
        TextSize = 12,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        Parent = card
    })

    -- Progress bar
    local bar = U.New("Frame", {
        BackgroundColor3 = col,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 1, -2),
        Size = UDim2.new(1, 0, 0, 2),
        Parent = card
    })

    -- Open
    U.Tween(card, T.Spring, { Size = UDim2.new(1, 0, 0, 78) })

    -- Progress
    U.Tween(bar, TweenInfo.new(duration, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 0, 2) })

    -- Close
    local function close()
        U.Tween(card, T.Fast, { Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1 })
        task.delay(0.2, function() card:Destroy() end)
    end

    local xBtn = U.New("TextButton", {
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -26, 0, 6),
        Size = UDim2.new(0, 20, 0, 20),
        Font = Enum.Font.GothamBold,
        Text = "✕",
        TextColor3 = T.TextD,
        TextSize = 14,
        Parent = card
    })
    xBtn.MouseButton1Click:Connect(close)
    task.delay(duration, close)
end

