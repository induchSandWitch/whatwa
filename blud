        Parent = iconContainer,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Image = data.Icon or "rbxassetid://7733921626",
        ImageColor3 = accentColor
    })
    
    -- Title with gradient text effect (simulated)
    local titleLabel = Utility:Create("TextLabel", {
        Parent = notification,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 72, 0, 16),
        Size = UDim2.new(1, -100, 0, 22),
        Font = Enum.Font.GothamBold,
        Text = title,
        TextColor3 = Theme.Colors.Text,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    local descLabel = Utility:Create("TextLabel", {
        Parent = notification,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 72, 0, 40),
        Size = UDim2.new(1, -90, 0, 50),
        Font = Enum.Font.Gotham,
        Text = description,
        TextColor3 = Theme.Colors.TextMuted,
        TextSize = 13,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top
    })
    
    -- Progress bar with gradient
    local progressContainer = Utility:Create("Frame", {
        Parent = notification,
        BackgroundColor3 = Theme.Colors.BackgroundSecondary,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 16, 1, -6),
        Size = UDim2.new(1, -32, 0, 3)
    })
    Utility:Corner(2).Parent = progressContainer
    
    local progressBar = Utility:Create("Frame", {
        Parent = progressContainer,
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0)
    })
    Utility:Corner(2).Parent = progressBar
    
    local progressGradient = Utility:Gradient(0, ColorSequence.new({
        ColorSequenceKeypoint.new(0, accentColor),
        ColorSequenceKeypoint.new(1, Theme.Colors.Primary)
    }))
    progressGradient.Parent = progressBar
    
    -- Close button
    local closeBtn = Utility:Create("TextButton", {
        Parent = notification,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -36, 0, 12),
        Size = UDim2.new(0, 24, 0, 24),
        Font = Enum.Font.GothamBold,
        Text = "×",
        TextColor3 = Theme.Colors.TextMuted,
        TextSize = 20
    })
    
    closeBtn.MouseEnter:Connect(function()
        Utility:Tween(closeBtn, Theme.Easing.Fast, {TextColor3 = Theme.Colors.Error}):Play()
    end)
    closeBtn.MouseLeave:Connect(function()
        Utility:Tween(closeBtn, Theme.Easing.Fast, {TextColor3 = Theme.Colors.TextMuted}):Play()
    end)
    
    -- Entrance animation
    notification.Size = UDim2.new(0, 340, 0, 0)
    Utility:Tween(notification, Theme.Easing.Elastic, {Size = UDim2.new(0, 340, 0, 100)}):Play()
    
    -- Progress animation
    Utility:Tween(progressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 1, 0)}):Play()
    
    -- Close function
    local function close()
        Utility:Tween(notification, Theme.Easing.Fast, {
            Size = UDim2.new(0, 340, 0, 0),
            BackgroundTransparency = 1
        }):Play()
        task.wait(0.3)
        notification:Destroy()
    end
    
    closeBtn.MouseButton1Click:Connect(close)
    task.delay(duration, close)
    
    return notification
end

