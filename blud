            BackgroundTransparency = 0.8,
            BorderSizePixel = 0,
            Position = UDim2.new(1, -100, 0.5, -14),
            Size = UDim2.new(0, 80, 0, 28)
        })
        Utility:Corner(6).Parent = bindContainer
        
        local bindBtn = Utility:Create("TextButton", {
            Parent = bindContainer,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            Font = Enum.Font.GothamBold,
            Text = keybind.Value and tostring(keybind.Value):gsub("Enum.KeyCode.", "") or "NONE",
            TextColor3 = Theme.Colors.Text,
            TextSize = 12
        })
        
        local listening = false
        
        bindBtn.MouseButton1Click:Connect(function()
            if listening then return end
            listening = true
            bindBtn.Text = "..."
            
            local connection
            connection = Services.UserInputService.InputBegan:Connect(function(input)
                if input.KeyCode ~= Enum.KeyCode.Unknown then
                    keybind.Value = input.KeyCode
                    bindBtn.Text = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
                    
                    Utility:Tween(bindContainer, Theme.Easing.Fast, {BackgroundTransparency = 0.5}):Play()
                    task.wait(0.1)
                    Utility:Tween(bindContainer, Theme.Easing.Fast, {BackgroundTransparency = 0.8}):Play()
                    
                    if data.Callback then
                        data.Callback(input.KeyCode)
                    end
                    
                    listening = false
                    connection:Disconnect()
                end
            end)
        end)
        
        keybind.Set = function(self, key)
            keybind.Value = key
            bindBtn.Text = key and tostring(key):gsub("Enum.KeyCode.", "") or "NONE"
        end
        
