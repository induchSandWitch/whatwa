-- Particle System for ambient effects
local ParticleSystem = {}
ParticleSystem.__index = ParticleSystem

function ParticleSystem.new(parent, count)
    local self = setmetatable({}, ParticleSystem)
    self.Parent = parent
    self.Particles = {}
    self.Active = true
    
    for i = 1, count or 20 do
        self:CreateParticle()
    end
    
    return self
end

function ParticleSystem:CreateParticle()
    local particle = Utility:Create("Frame", {
        Parent = self.Parent,
        BackgroundColor3 = Theme.Colors.Primary,
        BackgroundTransparency = 0.8,
        BorderSizePixel = 0,
        Size = UDim2.new(0, math.random(2, 6), 0, math.random(2, 6)),
        Position = UDim2.new(math.random(), 0, math.random(), 0),
        ZIndex = -5
    })
    
    Utility:Corner(50).Parent = particle
    
    -- Random color from palette
    local colors = {Theme.Colors.Primary, Theme.Colors.Secondary, Theme.Colors.Tertiary}
    particle.BackgroundColor3 = colors[math.random(1, #colors)]
    
    table.insert(self.Particles, {
        Instance = particle,
        Speed = math.random(5, 15) / 100,
        Direction = math.random() * math.pi * 2,
        Life = math.random(50, 100)
    })
    
    self:AnimateParticle(self.Particles[#self.Particles])
end

function ParticleSystem:AnimateParticle(data)
    task.spawn(function()
        while self.Active and data.Instance.Parent do
            local currentPos = data.Instance.Position
            local newX = currentPos.X.Scale + math.cos(data.Direction) * data.Speed
            local newY = currentPos.Y.Scale + math.sin(data.Direction) * data.Speed
            
            -- Bounce off edges
            if newX < 0 or newX > 1 then
                data.Direction = math.pi - data.Direction
                newX = math.clamp(newX, 0, 1)
            end
            if newY < 0 or newY > 1 then
                data.Direction = -data.Direction
                newY = math.clamp(newY, 0, 1)
            end
            
            data.Instance.Position = UDim2.new(newX, 0, newY, 0)
            
            -- Fade in/out
            data.Life = data.Life - 1
            if data.Life <= 0 then
                data.Life = 100
                data.Instance.BackgroundTransparency = 0.9
                Utility:Tween(data.Instance, Theme.Easing.Slow, {BackgroundTransparency = 0.4}):Play()
                task.wait(2)
                Utility:Tween(data.Instance, Theme.Easing.Slow, {BackgroundTransparency = 0.9}):Play()
            end
            
            task.wait(0.05)
        end
    end)
end

-- Magnetic Button Effect
local MagneticButton = {}
MagneticButton.__index = MagneticButton

function MagneticButton.new(button, strength)
    local self = setmetatable({}, MagneticButton)
    self.Button = button
    self.Strength = strength or 0.3
    self.OriginalPosition = button.Position
    self.IsHovering = false
    
    button.MouseEnter:Connect(function() self:IsHover() end)
    button.MouseLeave:Connect(function() self:IsLeave() end)
    button.MouseMoved:Connect(function(x, y) self:OnMove(x, y) end)
    
    return self
end

function MagneticButton:IsHover()
    self.IsHovering = true
    Utility:Tween(self.Button, Theme.Easing.Fast, {Size = UDim2.new(
        self.Button.Size.X.Scale,
        self.Button.Size.X.Offset + 4,
        self.Button.Size.Y.Scale,
        self.Button.Size.Y.Offset + 4
    )}):Play()
end

function MagneticButton:IsLeave()
    self.IsHovering = false
    Utility:Tween(self.Button, Theme.Easing.Fast, {
        Position = self.OriginalPosition,
        Size = UDim2.new(
            self.Button.Size.X.Scale,
            self.Button.Size.X.Offset - 4,
            self.Button.Size.Y.Scale,
            self.Button.Size.Y.Offset - 4
        )
    }):Play()
end

function MagneticButton:OnMove(x, y)
    if not self.IsHovering then return end
    
    local absPos = self.Button.AbsolutePosition
    local absSize = self.Button.AbsoluteSize
    local center = Vector2.new(absPos.X + absSize.X/2, absPos.Y + absSize.Y/2)
    local mousePos = Vector2.new(x, y)
    local offset = (mousePos - center) * self.Strength
    
    Utility:Tween(self.Button, Theme.Easing.Instant, {
        Position = UDim2.new(
            self.OriginalPosition.X.Scale,
            self.OriginalPosition.X.Offset + offset.X,
            self.OriginalPosition.Y.Scale,
            self.OriginalPosition.Y.Offset + offset.Y
        )
    }):Play()
end

-- Glow Effect
function Utility:AddGlow(parent, color)
    local glow = Utility:Create("ImageLabel", {
        Parent = parent,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5, -50, 0.5, -50),
        Size = UDim2.new(0, 100, 0, 100),
        Image = "rbxassetid://6015897843",
        ImageColor3 = color or Theme.Colors.Primary,
        ImageTransparency = 0.9,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        ZIndex = parent.ZIndex - 1
    })
    
    -- Pulse animation
    task.spawn(function()
        while parent.Parent do
            Utility:Tween(glow, Theme.Easing.Slow, {ImageTransparency = 0.85}):Play()
            task.wait(1.5)
            Utility:Tween(glow, Theme.Easing.Slow, {ImageTransparency = 0.95}):Play()
            task.wait(1.5)
        end
    end)
    
    return glow
end

-- Draggable with momentum
function Utility:MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging = false
    local dragStart = nil
    local startPos = nil
    local velocity = Vector2.new(0, 0)
    local lastPos = nil
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            lastPos = input.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    -- Apply momentum
                    if velocity.Magnitude > 5 then
                        local targetX = frame.Position.X.Offset + velocity.X * 2
                        local targetY = frame.Position.Y.Offset + velocity.Y * 2
                        Utility:Tween(frame, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
                            Position = UDim2.new(frame.Position.X.Scale, targetX, frame.Position.Y.Scale, targetY)
                        }):Play()
                    end
                end
            end)
        end
    end)
    
    Services.UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            velocity = input.Position - lastPos
            lastPos = input.Position
            
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

