            Text = tostring(slider.Value),
            TextColor3 = tab.Color,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Right
        })
        
        -- Slider track with gradient
        local track = Utility:Create("Frame", {
            Parent = container,
            BackgroundColor3 = Theme.Colors.BackgroundSecondary,
            BorderSizePixel = 0,
            Position = UDim2.new(0, 16, 0, 44),
            Size = UDim2.new(1, -32, 0, 8)
        })
        Utility:Corner(4).Parent = track
        
        -- Fill with animated gradient
        local fill = Utility:Create("Frame", {
            Parent = track,
            BackgroundColor3 = tab.Color,
            BorderSizePixel = 0,
            Size = UDim2.new((slider.Value - slider.Min) / (slider.Max - slider.Min), 0, 1, 0)
        })
        Utility:Corner(4).Parent = fill
        
        local fillGradient = Utility:Gradient(0, ColorSequence.new({
            ColorSequenceKeypoint.new(0, tab.Color),
            ColorSequenceKeypoint.new(1, Theme.Colors.Secondary)
        }))
        fillGradient.Parent = fill
        
        -- Glowing knob
        local knobContainer = Utility:Create("Frame", {
            Parent = track,
            BackgroundTransparency = 1,
            Position = UDim2.new((slider.Value - slider.Min) / (slider.Max - slider.Min), -8, 0.5, -8),
            Size = UDim2.new(0, 16, 0, 16)
        })
        
        local knobGlow = Utility:AddGlow(knobContainer, tab.Color)
        knobGlow.Size = UDim2.new(0, 32, 0, 32)
        knobGlow.Position = UDim2.new(0.5, -16, 0.5, -16)
        
        local knob = Utility:Create("Frame", {
            Parent = knobContainer,
            BackgroundColor3 = Color3.new(1, 1, 1),
            BorderSizePixel = 0,
            Size = UDim2.new(1, 0, 1, 0)
        })
        Utility:Corner(8).Parent = knob
        
        local dragging = false
        
        local function update(input)
            local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            local value = math.floor(slider.Min + (pos * (slider.Max - slider.Min)))
            
            if data.Round then
                value = math.floor(value / data.Round) * data.Round
                pos = (value - slider.Min) / (slider.Max - slider.Min)
            end
            
            slider.Value = value
            valueLabel.Text = tostring(value) .. (data.Suffix or "")
            
            Utility:Tween(fill, Theme.Easing.Instant, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
            Utility:Tween(knobContainer, Theme.Easing.Instant, {Position = UDim2.new(pos, -8, 0.5, -8)}):Play()
            
            if data.Callback then
                data.Callback(value)
            end
        end
        
        track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                update(input)
                Utility:Tween(knobContainer, Theme.Easing.Fast, {Size = UDim2.new(0, 20, 0, 20)}):Play()
                Utility:Tween(knobContainer, Theme.Easing.Fast, {Position = UDim2.new(knobContainer.Position.X.Scale, -10, 0.5, -10)}):Play()
            end
        end)
        
        Services.UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                update(input)
            end
        end)
        
        Services.UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
                Utility:Tween(knobContainer, Theme.Easing.Bounce, {Size = UDim2.new(0, 16, 0, 16)}):Play()
                Utility:Tween(knobContainer, Theme.Easing.Bounce, {Position = UDim2.new(knobContainer.Position.X.Scale, -8, 0.5, -8)}):Play()
            end
        end)
        
        slider.Set = function(self, value)
            value = math.clamp(value, slider.Min, slider.Max)
            slider.Value = value
            valueLabel.Text = tostring(value) .. (data.Suffix or "")
            local pos = (value - slider.Min) / (slider.Max - slider.Min)
            Utility:Tween(fill, Theme.Easing.Normal, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
            Utility:Tween(knobContainer, Theme.Easing.Normal, {Position = UDim2.new(pos, -8, 0.5, -8)}):Play()
            if data.Callback then data.Callback(value) end
        end
        
        return slider
    end
    
