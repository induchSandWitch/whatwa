function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end
    
    -- Deselect current
    if self.ActiveTab then
        local btn = self.ActiveTab.Button
        local icon = btn:FindFirstChildOfClass("ImageLabel")
        local label = btn:FindFirstChildOfClass("TextLabel")
        local indicator = btn:FindFirstChildOfClass("Frame")
        
        Utility:Tween(btn, Theme.Easing.Fast, {BackgroundTransparency = 1}):Play()
        if icon then Utility:Tween(icon, Theme.Easing.Fast, {ImageColor3 = Theme.Colors.TextMuted}):Play() end
        if label then Utility:Tween(label, Theme.Easing.Fast, {TextColor3 = Theme.Colors.TextMuted}):Play() end
        if indicator then Utility:Tween(indicator, Theme.Easing.Fast, {BackgroundTransparency = 1}):Play() end
        
        -- Fade out content
        Utility:Tween(self.ActiveTab.Content, Theme.Easing.Fast, {ScrollBarImageTransparency = 1}):Play()
        self.ActiveTab.Content.Visible = false
    end
    
    -- Select new
    self.ActiveTab = tab
    
    local btn = tab.Button
    local icon = btn:FindFirstChildOfClass("ImageLabel")
    local label = btn:FindFirstChildOfClass("TextLabel")
    local indicator = btn:FindFirstChildOfClass("Frame")
    local gradient = btn:FindFirstChildOfClass("UIGradient")
    
    Utility:Tween(btn, Theme.Easing.Bounce, {BackgroundTransparency = 0.7}):Play()
    if gradient then Utility:Tween(gradient, Theme.Easing.Fast, {Transparency = NumberSequence.new(0.8)}):Play() end
    if icon then Utility:Tween(icon, Theme.Easing.Fast, {ImageColor3 = tab.Color}):Play() end
    if label then Utility:Tween(label, Theme.Easing.Fast, {TextColor3 = Theme.Colors.Text}):Play() end
    if indicator then Utility:Tween(indicator, Theme.Easing.Bounce, {BackgroundTransparency = 0}):Play() end
    
    tab.Content.Visible = true
    Utility:Tween(tab.Content, Theme.Easing.Fast, {ScrollBarImageTransparency = 0.5}):Play()
end

function Window:Notify(data)
    return self.Notifications:Notify(data)
end

function Window:Close()
    self.Particles.Active = false
    
    Utility:Tween(self.Main, Theme.Easing.Slow, {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundTransparency = 1
    }):Play()
    
    task.wait(0.5)
    self.Gui:Destroy()
end

function Window:Minimize()
    self.Minimized = not self.Minimized
    
    if self.Minimized then
        Utility:Tween(self.Main, Theme.Easing.Bounce, {
            Size = UDim2.new(0, self.Size.X.Offset, 0, 60)
        }):Play()
    else
        Utility:Tween(self.Main, Theme.Easing.Bounce, {
            Size = self.Size
        }):Play()
    end
end

-- Library Interface
function Sirius:Init(data)
    return Window.new(data)
end

function Sirius:Notify(data)
    local tempGui = Utility:Create("ScreenGui", {
        Name = "SiriusTempNotifications",
        Parent = Services.CoreGui
    })
    local notifSystem = NotificationSystem.new(tempGui)
    return notifSystem:Notify(data)
end

return Sirius
