local Util = {}
function Util.Create(class, props)
    local obj = Instance.new(class)
    if props then
        for k,v in pairs(props) do
            if k ~= "Parent" then
                local ok, _ = pcall(function() obj[k] = v end)
            end
        end
        if props.Parent then obj.Parent = props.Parent end
    end
    return obj
end
function Util.Tween(obj, ti, props)
    local tween = Services.TweenService:Create(obj, ti or TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
    tween:Play()
    return tween
end
function Util.MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    Services.UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end
function Util.ClampText(label)
    label.TextWrapped = true
    label.TextScaled = false
    local function fit()
        if not label:IsDescendantOf(game) then return end
        local size = label.TextBounds
        local avail = label.AbsoluteSize
        if avail.X <= 1 then return end
        local ratio = math.min(1, (avail.X - 8) / math.max(1, size.X))
        label.TextSize = math.max(10, math.floor((label.TextSize or 14) * ratio))
    end
    label:GetPropertyChangedSignal("AbsoluteSize"):Connect(fit)
    label:GetPropertyChangedSignal("Text"):Connect(fit)
    task.defer(fit)
end
function Util.SafeSet(inst, prop, val)
    pcall(function() inst[prop] = val end)
end
function Util.MakeRound(frame, radius)
    Util.Create("UICorner",{Parent = frame, CornerRadius = UDim.new(0, radius or 8)})
end
function Util.UIDestroyChildren(parent, className)
    for i,child in pairs(parent:GetChildren()) do
        if not className or child:IsA(className) then
            child:Destroy()
        end
    end
end

