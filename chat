local Ripple = {}
function Ripple.Emit(parent, pos, color)
    local size = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
    local img = Util.Create("ImageLabel",{Parent = parent, AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(0, pos.X, 0, pos.Y), Size = UDim2.new(0, 8, 0, 8), BackgroundTransparency = 1, Image = "rbxassetid://4833223430", ImageColor3 = color or Theme.AccentA, ImageTransparency = 0.5, ZIndex = 30})
    pcall(function() img.ScaleType = Enum.ScaleType.Slice end)
    Util.Tween(img, TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Size = UDim2.new(0, size, 0, size), ImageTransparency = 1})
    task.delay(0.68, function() pcall(function() img:Destroy() end) end)
end

