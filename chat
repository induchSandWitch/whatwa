    local modal = Util.Create("Frame",{Parent = self.Gui, AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(0.5,0.5,0.5,0), Size = UDim2.new(0,420,0,180), BackgroundColor3 = Theme.Panel, ZIndex = 50})
