local function ApplyBlur(enable, amount)
    local blur = Services.Lighting:FindFirstChild("SiriusUltra_Blur")
    if enable then
        if not blur then
            blur = Instance.new("BlurEffect")
            blur.Name = "SiriusUltra_Blur"
            blur.Parent = Services.Lighting
            blur.Size = 0
        end
        Util.Tween(blur, Tweens.Normal, {Size = amount or 12})
    else
        if blur then
            Util.Tween(blur, Tweens.Normal, {Size = 0})
            task.delay(0.4, function() if blur and blur.Size <= 0.1 then pcall(function() blur:Destroy() end) end end)
        end
    end
end

