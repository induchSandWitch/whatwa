function WindowClass:SelectTab(tab)
    if self.ActiveTab == tab then return end
    for _,t in ipairs(self.Tabs) do
        if t.Content then t.Content.Visible = false end
        if t.Button then Util.Tween(t.Button, Tweens.Fast, {BackgroundTransparency = 0}); local img = t.Button:FindFirstChildOfClass("ImageLabel"); local lbl = t.Button:FindFirstChildOfClass("TextLabel"); if img then Util.Tween(img, Tweens.Fast, {ImageColor3 = Theme.TextDim}) end; if lbl then Util.Tween(lbl, Tweens.Fast, {TextColor3 = Theme.TextDim}) end
    end
    self.ActiveTab = tab
    if tab.Content then tab.Content.Visible = true end
    if tab.Button then Util.Tween(tab.Button, Tweens.Fast, {BackgroundTransparency = 0.02}); local img = tab.Button:FindFirstChildOfClass("ImageLabel"); local lbl = tab.Button:FindFirstChildOfClass("TextLabel"); if img then Util.Tween(img, Tweens.Fast, {ImageColor3 = Theme.Text}) end; if lbl then Util.Tween(lbl, Tweens.Fast, {TextColor3 = Theme.Text}) end
end

