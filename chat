function WindowClass:LoadSettings()
    local stored = nil
    local ok, raw = pcall(function()
        if LocalPlayer and LocalPlayer:FindFirstChild("PlayerGui") then
            return LocalPlayer:GetAttribute(self.SettingsKey) or LocalPlayer:GetAttribute(self.SettingsKey) or nil
        end
        return nil
    end)
    if ok and raw then
        local suc, dec = pcall(function() return Services.HttpService:JSONDecode(raw) end)
        if suc and type(dec) == "table" then return dec end
    end
    return {Theme = {AccentA = Theme.AccentA, AccentB = Theme.AccentB}}
end
function WindowClass:SaveSettings()
    local raw = Services.HttpService:JSONEncode(self.Settings)
    pcall(function() if LocalPlayer then LocalPlayer:SetAttribute(self.SettingsKey, raw) end end)
end

function WindowClass:SearchInternal(query)
    local results = {}
    for _,tab in ipairs(self.Tabs) do
        for _,child in ipairs(tab.Content:GetChildren()) do
            if child:IsA("Frame") or child:IsA("TextLabel") then
                local txt = child:FindFirstChildWhichIsA("TextLabel") and child:FindFirstChildWhichIsA("TextLabel").Text or child.Name
                if string.find(string.lower(txt), string.lower(query)) then
                    table.insert(results, {Tab = tab, Element = child, Text = txt})
                end
            end
        end
    end
    if #results == 0 then
        self:Notify({Title = "Search", Text = "No matches for '"..query.."'", Duration = 2})
        return
    end
    for _,r in ipairs(results) do
        Util.Tween(r.Element, Tweens.Pop, {BackgroundTransparency = 0.05})
        task.delay(0.5, function() if r.Element and r.Element.Parent then Util.Tween(r.Element, Tweens.Fast, {BackgroundTransparency = 0}) end end)
    end
    self:Notify({Title = "Search", Text = "Found "..tostring(#results).." matches", Duration = 2})
end

