    local desc = Util.Create("TextLabel",{Parent = modal, Position = UDim2.new(0,18,0,48), Size = UDim2.new(1,-36,0,60), BackgroundTransparency = 1, Font = Enum.Font.Gotham, Text = opts.Text or "Are you sure?", TextColor3 = Theme.TextDim, TextSize = 13, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left})
    local yes = Util.Create("TextButton",{Parent = modal, Position = UDim2.new(0,18,1,-56), Size = UDim2.new(0,140,0,40), BackgroundColor3 = Theme.AccentA or Color3.fromRGB(0,200,255), Font = Enum.Font.GothamBold, Text = opts.ConfirmText or "Yes", TextColor3 = Color3.new(1,1,1)})
    local no = Util.Create("TextButton",{Parent = modal, Position = UDim2.new(1,-158,1,-56), Size = UDim2.new(0,140,0,40), BackgroundColor3 = Theme.BgSoft, Font = Enum.Font.GothamBold, Text = opts.CancelText or "Cancel", TextColor3 = Theme.Text})
    Util.MakeRound(yes,8)
    Util.MakeRound(no,8)
    local resolved = false
    local function close()
        if not modal then return end
        Util.Tween(modal, Tweens.Fast, {Size = UDim2.new(0,0,0,0), BackgroundTransparency = 1})
        task.delay(0.2, function() pcall(function() modal:Destroy() end) end)
    end
    yes.MouseButton1Click:Connect(function() if not resolved and opts.OnConfirm then pcall(function() opts.OnConfirm() end) end resolved = true close() end)
    no.MouseButton1Click:Connect(function() if not resolved and opts.OnCancel then pcall(function() opts.OnCancel() end) end resolved = true close() end)
    return modal
