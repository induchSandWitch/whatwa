local function gradientFor(colors, rotation)
    local g = Utility:Create("UIGradient", {Rotation = rotation or 0})
    g.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, colors[1]), ColorSequenceKeypoint.new(1, colors[2])})
    return g
end

