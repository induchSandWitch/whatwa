        local fillCorner = Utility:Create("UICorner", {Parent = fill, CornerRadius = UDim.new(1,0)})
        local knob = Utility:Create("Frame", {Parent = bar, BackgroundColor3 = Color3.new(1,1,1), Size = UDim2.new(0,16,0,16), Position = UDim2.new((s.Value - s.Min)/(s.Max - s.Min), -8, 0.5, -8)})
        local knobCorner = Utility:Create("UICorner", {Parent = knob, CornerRadius = UDim.new(1,0)})
        local dragging = false
        local function update(input)
            local pos = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
            local val = math.floor(s.Min + pos * (s.Max - s.Min))
            s.Value = val
            valLbl.Text = tostring(val)
            Utility:Tween(fill, Theme.Anim.Quick, {Size = UDim2.new(pos,0,1,0)})
            Utility:Tween(knob, Theme.Anim.Quick, {Position = UDim2.new(pos, -8, 0.5, -8)})
            if d.Callback then pcall(function() d.Callback(val) end) end
        end
        bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(i) end end)
        Services.UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end end)
        Services.UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
        s.Set = function(_, value) value = math.clamp(value, s.Min, s.Max) s.Value = value valLbl.Text = tostring(value) local pos = (value - s.Min)/(s.Max - s.Min) Utility:Tween(fill, Theme.Anim.Smooth, {Size = UDim2.new(pos,0,1,0)}) Utility:Tween(knob, Theme.Anim.Smooth, {Position = UDim2.new(pos,-8,0.5,-8)}) if d.Callback then pcall(function() d.Callback(value) end) end end
        return s
    end

