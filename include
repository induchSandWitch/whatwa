    local function ripple(parent, pos)
        local r = Utility:Create("Frame", {Parent = parent, BackgroundColor3 = Color3.new(1,1,1), Size = UDim2.new(0,8,0,8), Position = UDim2.new(0,pos.X - parent.AbsolutePosition.X,0,pos.Y - parent.AbsolutePosition.Y), AnchorPoint = Vector2.new(0.5,0.5), BackgroundTransparency = 0.6, ZIndex = parent.ZIndex + 2})
