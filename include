    end)
    self.SearchBox.FocusLost:Connect(function(enter)
        Utility:Tween(icon, Theme.Anim.Quick, {ImageColor3 = Theme.Colors.SubText})
        if enter and #self.SearchBox.Text > 0 then
            self:Search(self.SearchBox.Text)
        else
            self:Close()
        end
    end)
    Services.UserInputService.InputBegan:Connect(function(input, gp)
        if input.KeyCode == Enum.KeyCode.Escape and self.Visible then
            self:Close()
        end
    end)
