function ScriptSearch:Open()
    if self.Visible then return end
    self.Visible = true
    self.Container.Visible = true
    self.Container.Size = UDim2.new(0,480,0,23)
    self.Container.Position = UDim2.new(0.5,-240,0.5,0)
    Utility:Tween(self.Container, Theme.Anim.Smooth, {Size = UDim2.new(0,580,0,43), Position = UDim2.new(0.5,-290,0.5,-20)})
    task.wait(0.26)
    self.SearchBox:CaptureFocus()
end

function ScriptSearch:Close()
    if not self.Visible then return end
    self.Visible = false
    Utility:Tween(self.Container, Theme.Anim.Smooth, {Size = UDim2.new(0,520,0,0)})
    self.SearchBox.Text = ""
    self.ResultsFrame.Visible = false
    task.wait(0.32)
    self.Container.Visible = false
end

function ScriptSearch:Search(query)
    self.ResultsFrame.Visible = true
    for _,c in pairs(self.ResultsFrame:GetChildren()) do if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end end
    local loading = Utility:Create("TextLabel", {Parent = self.ResultsFrame, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,40), Font = Enum.Font.Gotham, Text = "Searching...", TextColor3 = Theme.Colors.SubText, TextSize = 14})
    Utility:Tween(self.Container, Theme.Anim.Smooth, {Size = UDim2.new(0,580,0,520)})
    task.spawn(function()
        local ok, result = pcall(function()
            local url = "https://scriptblox.com/api/script/search?q=" .. Services.HttpService:UrlEncode(query) .. "&mode=free&max=20&page=1"
            local response = request({Url = url, Method = "GET"})
            return Services.HttpService:JSONDecode(response.Body)
        end)
        loading:Destroy()
        if ok and result and result.result and #result.result.scripts > 0 then
            for _,d in ipairs(result.result.scripts) do
                self:CreateScriptCard(d)
            end
        else
            Utility:Create("TextLabel", {Parent = self.ResultsFrame, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,60), Font = Enum.Font.GothamBold, Text = "No results", TextColor3 = Theme.Colors.SubText, TextSize = 16})
        end
        local layout = self.ResultsFrame:FindFirstChildOfClass("UIListLayout")
        if layout then
            self.ResultsFrame.Size = UDim2.new(1,0,0, layout.AbsoluteContentSize.Y)
        end
    end)
end

