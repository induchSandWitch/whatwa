function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end
    if self.ActiveTab then
        Utility:Tween(self.ActiveTab.Button, Theme.Anim.Quick, {BackgroundTransparency = 0})
        local oldIcon = self.ActiveTab.Button:FindFirstChildOfClass("ImageLabel")
        if oldIcon then Utility:Tween(oldIcon, Theme.Anim.Quick, {ImageColor3 = Theme.Colors.SubText}) end
        local oldLabel = self.ActiveTab.Button:FindFirstChildOfClass("TextLabel")
        if oldLabel then Utility:Tween(oldLabel, Theme.Anim.Quick, {TextColor3 = Theme.Colors.SubText}) end
        self.ActiveTab.Content.Visible = false
    end
    self.ActiveTab = tab
    Utility:Tween(tab.Button, Theme.Anim.Quick, {BackgroundTransparency = 0.06})
    local icon = tab.Button:FindFirstChildOfClass("ImageLabel")
    if icon then Utility:Tween(icon, Theme.Anim.Quick, {ImageColor3 = tab.Color}) end
    local label = tab.Button:FindFirstChildOfClass("TextLabel")
    if label then Utility:Tween(label, Theme.Anim.Quick, {TextColor3 = Theme.Colors.Text}) end
    tab.Content.Visible = true
end

function Window:Notify(data)
    return self.Notifications:Notify(data)
end

function Window:Close()
    local blur = Services.Lighting:FindFirstChild("SiriusXBlur")
    if blur then Utility:Tween(blur, Theme.Anim.Smooth, {Size = 0}) end
    Utility:Tween(self.Main, Theme.Anim.Smooth, {Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0.5,0)})
    task.wait(0.36)
    pcall(function() self.Gui:Destroy() end)
end

function Window:Minimize()
    self.Minimized = not self.Minimized
    if self.Minimized then
        Utility:Tween(self.Main, Theme.Anim.Smooth, {Size = UDim2.new(0,self.Size.X.Offset,0,60)})
    else
        Utility:Tween(self.Main, Theme.Anim.Smooth, {Size = self.Size})
    end
end

function Sirius:Init(data)
    return Window.new(data)
end

function Sirius:Notify(data)
    local notifGui = Utility:Create("ScreenGui", {Name = "SiriusNotificationsTemp", Parent = Services.CoreGui})
    local ns = NotificationSystem.new(notifGui)
    return ns:Notify(data)
end

return Sirius
