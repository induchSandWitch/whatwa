    local title = Utility:Create("TextLabel", {Parent = card, BackgroundTransparency = 1, Position = UDim2.new(0,16,0,12), Size = UDim2.new(1,-150,0,28), Font = Enum.Font.GothamBold, Text = data.title or "Unknown", TextColor3 = Theme.Colors.Text, TextSize = 16, TextXAlignment = Enum.TextXAlignment.Left, TextScaled = true})
