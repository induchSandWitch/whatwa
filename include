        local mouse = Services.Players.LocalPlayer:GetMouse()
        ripple(execBtn, Vector2.new(mouse.X, mouse.Y))
        local ok,err = pcall(function() loadstring(data.script)() end)
        if ok then
            -- visually show success
        else
            warn("Exec error", err)
        end
    end)

    card.MouseEnter:Connect(function()
        Utility:Tween(card, Theme.Anim.Quick, {BackgroundTransparency = 0.06})
        Utility:Tween(stroke, Theme.Anim.Quick, {Transparency = 0.2})
    end)
