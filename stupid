-- Utility Functions
local Utility = {}

function Utility:Create(class, properties)
    local instance = Instance.new(class)
    for prop, value in pairs(properties or {}) do
        if prop == "Parent" then continue end
        instance[prop] = value
    end
    if properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Utility:Tween(instance, info, properties)
    local tween = Services.TweenService:Create(instance, info, properties)
    tween:Play()
    return tween
end

function Utility:MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragInput, dragStart, startPos
   
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
           
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
   
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
   
    Services.UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

function Utility:Round(number, precision)
    precision = precision or 0
    local mult = 10 ^ precision
    return math.floor(number * mult + 0.5) / mult
end

function Utility:FormatTime(seconds)
    local mins = math.floor(seconds / 60)
    local secs = seconds % 60
    return string.format("%02d:%02d", mins, secs)
end

-- Ripple Effect System (for premium button clicks)
function Utility:CreateRipple(parent, color)
    local ripple = Utility:Create("Frame", {
        Parent = parent,
        BackgroundColor3 = color or Color3.fromRGB(255, 255, 255),
        BackgroundTransparency = 0.6,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = 10
    })
    
    local corner = Utility:Create("UICorner", {
        Parent = ripple,
        CornerRadius = UDim.new(1, 0)
    })
    
    local goalSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.5
    Utility:Tween(ripple, TweenInfo.new(0.6, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, goalSize, 0, goalSize),
        BackgroundTransparency = 1
    }):Play()
    
    task.delay(0.6, function()
        ripple:Destroy()
    end)
end

-- Glow System (reusable neon glow)
function Utility:ApplyGlow(frame, color, intensity)
    intensity = intensity or 0.3
    
    -- Outer glow layer 1
    local glow1 = Utility:Create("ImageLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, -15, 0, -15),
        Size = UDim2.new(1, 30, 1, 30),
        Image = "rbxassetid://6015897843",
        ImageColor3 = color,
        ImageTransparency = intensity,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        ZIndex = frame.ZIndex - 1
    })
    
    -- Outer glow layer 2 (stronger)
    local glow2 = Utility:Create("ImageLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, -25, 0, -25),
        Size = UDim2.new(1, 50, 1, 50),
        Image = "rbxassetid://6015897843",
        ImageColor3 = color,
        ImageTransparency = intensity + 0.4,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        ZIndex = frame.ZIndex - 2
    })
    
    return {glow1, glow2}
end

