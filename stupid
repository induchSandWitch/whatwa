function ScriptSearch:Open()
    if self.Visible then return end
    self.Visible = true
    self.Container.Visible = true
    self.Container.Size = UDim2.new(0, 480, 0, 26)
    Utility:Tween(self.Container, Theme.Animation.Slow, {
        Size = UDim2.new(0, 620, 0, 52),
        Position = UDim2.new(0.5, -310, 0.5, -30)
    }):Play()
    task.wait(0.35)
    self.SearchBox:CaptureFocus()
end

function ScriptSearch:Close()
    if not self.Visible then return end
    Utility:Tween(self.Container, Theme.Animation.Normal, {Size = UDim2.new(0, 520, 0, 0)}):Play()
    for _, child in pairs(self.ResultsFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    self.ResultsFrame.Visible = false
    self.SearchBox.Text = ""
    task.wait(0.45)
    self.Container.Visible = false
    self.Visible = false
end

function ScriptSearch:Search(query)
    -- ... (full implementation preserved and enhanced with glow cards - full code continues in next part)
    self.ResultsFrame.Visible = true
    -- Clear
    for _, child in pairs(self.ResultsFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
   
    local loading = Utility:Create("TextLabel", {
        Parent = self.ResultsFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 50),
        Font = Enum.Font.GothamBold,
