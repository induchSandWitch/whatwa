        TextSize = 15
    })
   
    Utility:Tween(self.Container, Theme.Animation.Slow, {Size = UDim2.new(0, 620, 0, 520)}):Play()
   
    task.spawn(function()
        local success, result = pcall(function()
            local url = "https://scriptblox.com/api/script/search?q=" .. Services.HttpService:UrlEncode(query) .. "&mode=free&max=20&page=1"
            local response = request({Url = url, Method = "GET"})
            return Services.HttpService:JSONDecode(response.Body)
        end)
       
        loading:Destroy()
       
        if success and result and result.result then
            if #result.result.scripts == 0 then
                self:ShowNoResults()
            else
                for _, scriptData in ipairs(result.result.scripts) do
                    self:CreateScriptCard(scriptData)
                end
            end
        else
            self:ShowError()
        end
       
        self.ResultsFrame.CanvasSize = UDim2.new(0, 0, 0, self.ResultsFrame.UIListLayout.AbsoluteContentSize.Y + 20)
    end)
end

