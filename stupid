function Window:SelectTab(tab)
    if self.ActiveTab == tab then return end
    if self.ActiveTab then
        Utility:Tween(self.ActiveTab.Button, Theme.Animation.Fast, {BackgroundTransparency = 1}):Play()
        local oldIcon = self.ActiveTab.Button:FindFirstChildOfClass("ImageLabel")
        if oldIcon then Utility:Tween(oldIcon, Theme.Animation.Fast, {ImageColor3 = Theme.Colors.TextDark}):Play() end
        local oldLabel = self.ActiveTab.Button:FindFirstChildOfClass("TextLabel")
        if oldLabel then Utility:Tween(oldLabel, Theme.Animation.Fast, {TextColor3 = Theme.Colors.TextDark}):Play() end
        self.ActiveTab.Content.Visible = false
    end
   
    self.ActiveTab = tab
    Utility:Tween(tab.Button, Theme.Animation.Fast, {BackgroundTransparency = 0.55}):Play()
    local icon = tab.Button:FindFirstChildOfClass("ImageLabel")
    if icon then Utility:Tween(icon, Theme.Animation.Fast, {ImageColor3 = tab.Color}):Play() end
    local label = tab.Button:FindFirstChildOfClass("TextLabel")
    if label then Utility:Tween(label, Theme.Animation.Fast, {TextColor3 = Theme.Colors.Text}):Play() end
    tab.Content.Visible = true
end

function Window:Notify(data)
    return self.Notifications:Notify(data)
end

function Window:Close()
    Utility:Tween(self.Main, Theme.Animation.Normal, {Size = UDim2.new(0, 0, 0, 0)}):Play()
    task.wait(0.45)
    self.Gui:Destroy()
end

function Window:Minimize()
    self.Minimized = not self.Minimized
    if self.Minimized then
        Utility:Tween(self.Main, Theme.Animation.Normal, {Size = UDim2.new(0, self.Size.X.Offset, 0, 58)}):Play()
    else
        Utility:Tween(self.Main, Theme.Animation.Normal, {Size = self.Size}):Play()
    end
end

