    -- Toggle functionality
    local visible = false
    
    local function toggleWindow()
        visible = not visible
        window.Visible = visible
        
        if visible then
            window.Size = UDim2.new(0, 0, 0, 0)
            Quantum:Tween(window, {Size = UDim2.new(0, 850, 0, 550)}, 0.6, Enum.EasingStyle.Back)
            Quantum:Tween(orbital, {Position = UDim2.new(0.5, 0, 0.05, 0)}, 0.4)
        else
            Quantum:Tween(window, {Size = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In, function()
                window.Visible = false
            end)
            Quantum:Tween(orbital, {Position = UDim2.new(0.5, 0, 0.1, 0)}, 0.4)
        end
    end
    
    orbital.MouseButton1Click:Connect(toggleWindow)
    closeWin.MouseButton1Click:Connect(toggleWindow)
    searchTrigger.MouseButton1Click:Connect(function()
        Nexus:OpenSingularity()
    end)
    
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == keybind then
            toggleWindow()
        end
    end)
    
