                Quantum:Instance("UICorner", {Parent = optBtn, CornerRadius = UDim.new(0, 8)})
                
                optBtn.MouseButton1Click:Connect(function()
                    selected.Text = opt
                    toggle()
                    
                    if data.Flag then
                        Nexus.Signals[data.Flag] = opt
                    end
                    
                    if data.Callback then
                        data.Callback(opt)
                    end
                end)
                
                optBtn.MouseEnter:Connect(function()
                    Quantum:Tween(optBtn, {BackgroundTransparency = 0.2, TextColor3 = Nexus.Palette.Bright}, 0.2)
                end)
                
                optBtn.MouseLeave:Connect(function()
                    Quantum:Tween(optBtn, {BackgroundTransparency = 0.5, TextColor3 = Nexus.Palette.Hologram}, 0.2)
                end)
            end
            
            frame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
