                expanded = not expanded
                if expanded then
                    options.Visible = true
                    Quantum:Tween(arrow, {Rotation = 180}, 0.3)
                    Quantum:Tween(frame, {Size = UDim2.new(1, 0, 0, 70 + math.min(#(data.Options or {}) * 45, 200))}, 0.3)
                else
                    Quantum:Tween(arrow, {Rotation = 0}, 0.3)
                    Quantum:Tween(frame, {Size = UDim2.new(1, 0, 0, 60)}, 0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out, function()
                        options.Visible = false
                    end)
                end
            end
            
            -- Build options
            for _, opt in ipairs(data.Options or {}) do
                local optBtn = Quantum:Instance("TextButton", {
                    Parent = options,
