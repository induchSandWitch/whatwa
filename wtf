--// Quantum Utility System
local Quantum = {}

function Quantum:Instance(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then
            obj[k] = v
        end
    end
    if props and props.Parent then
        obj.Parent = props.Parent
    end
    return obj
end

function Quantum:Tween(obj, props, duration, style, dir, callback)
    local tween = TweenService:Create(obj, TweenInfo.new(
        duration or 0.4,
        style or Enum.EasingStyle.Exponential,
        dir or Enum.EasingDirection.Out
    ), props)
    if callback then tween.Completed:Connect(callback) end
    tween:Play()
    return tween
end

function Quantum:Ripple(parent, pos, color)
    local ripple = Quantum:Instance("Frame", {
        Parent = parent,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = pos or UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = color or Nexus.Palette.Core,
        BackgroundTransparency = 0.6,
        BorderSizePixel = 0,
        ZIndex = 9999
    })
    
    Quantum:Instance("UICorner", {Parent = ripple, CornerRadius = UDim.new(1, 0)})
    
    Quantum:Tween(ripple, {
        Size = UDim2.new(0, 200, 0, 200),
        BackgroundTransparency = 1
    }, 0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out, function()
        ripple:Destroy()
    end)
end

function Quantum:Glow(parent, color, intensity)
    local glow = Quantum:Instance("ImageLabel", {
        Parent = parent,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, 30, 1, 30),
        BackgroundTransparency = 1,
        Image = "rbxassetid://5028857084",
        ImageColor3 = color or Nexus.Palette.Core,
        ImageTransparency = 1 - (intensity or 0.5),
        ZIndex = parent.ZIndex - 1
    })
    return glow
end

function Quantum:HologramStroke(parent, color)
    local stroke = Quantum:Instance("UIStroke", {
        Parent = parent,
        Color = color or Nexus.Palette.Core,
        Thickness = 1.5,
        Transparency = 0.3,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    })
    
    -- Animate stroke
    spawn(function()
        while parent and parent.Parent do
            Quantum:Tween(stroke, {Transparency = 0.1}, 1)
            wait(1)
            Quantum:Tween(stroke, {Transparency = 0.5}, 1)
            wait(1)
        end
    end)
    
    return stroke
end

function Quantum:MakeDraggable(frame, handle)
    handle = handle or frame
    local dragging, dragStart, startPos
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

--// Particle Field System
function Nexus:CreateParticleField(parent)
    local field = Quantum:Instance("Frame", {
        Parent = parent,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 0
    })
    
    local particles = {}
    
    for i = 1, Nexus.Config.ParticleCount do
        local size = math.random(2, 6)
        local particle = Quantum:Instance("Frame", {
            Parent = field,
            Size = UDim2.new(0, size, 0, size),
            Position = UDim2.new(math.random(), 0, math.random(), 0),
            BackgroundColor3 = Nexus.Palette.Core,
            BackgroundTransparency = math.random(3, 8) / 10,
            BorderSizePixel = 0
        })
        
        Quantum:Instance("UICorner", {
            Parent = particle,
            CornerRadius = UDim.new(1, 0)
        })
        
        -- Animate particle
        spawn(function()
            while particle and particle.Parent do
                local newX = math.random()
                local newY = math.random()
                local duration = math.random(10, 20)
                
                Quantum:Tween(particle, {
                    Position = UDim2.new(newX, 0, newY, 0),
                    BackgroundTransparency = math.random(3, 8) / 10
                }, duration, Enum.EasingStyle.Linear)
                
                wait(duration)
            end
        end)
        
        table.insert(particles, particle)
    end
    
    return field
end

