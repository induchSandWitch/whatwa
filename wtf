                    Duration = 3
                })
                
                task.delay(0.5, function()
                    local success, err = pcall(function()
                        loadstring(data.script)()
                    end)
                    
                    if success then
                        Nexus:Notify({
                            Title = "INJECTION SUCCESSFUL",
                            Description = data.title .. " is now active",
                            Type = "Toxic",
                            Duration = 4
                        })
                    else
                        Nexus:Notify({
                            Title = "INJECTION FAILED",
                            Description = tostring(err),
                            Type = "Pulse",
                            Duration = 5
                        })
                    end
                end)
            end
        end)
        
        return card
    end
    
    -- Search Function
    local function performSearch(query)
        -- Clear results
        for _, child in pairs(resultsFrame:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end
        
        if #query < 2 then return end
        
        -- Loading state
        local loading = Quantum:Instance("TextLabel", {
            Parent = resultsFrame,
            Size = UDim2.new(1, 0, 0, 100),
            BackgroundTransparency = 1,
            Font = Enum.Font.Gotham,
            Text = "SCANNING NEURAL NETWORK...",
            TextColor3 = Nexus.Palette.Core,
            TextSize = 16
        })
        
        -- API Request
        task.spawn(function()
            local success, result = pcall(function()
                local response = request({
                    Url = "https://scriptblox.com/api/script/search?q=" .. 
                          HttpService:UrlEncode(query) .. "&mode=free&max=20&page=1",
                    Method = "GET",
                    Headers = {
                        ["User-Agent"] = "Nexus/1.0"
                    }
                })
                return HttpService:JSONDecode(response.Body)
            end)
            
            loading:Destroy()
            
            if success and result and result.result and result.result.scripts then
                if #result.result.scripts == 0 then
                    Quantum:Instance("TextLabel", {
                        Parent = resultsFrame,
                        Size = UDim2.new(1, 0, 0, 100),
                        BackgroundTransparency = 1,
                        Font = Enum.Font.Gotham,
                        Text = "NO SIGNAL DETECTED",
                        TextColor3 = Nexus.Palette.Ghost,
                        TextSize = 16
                    })
                    return
                end
                
                for _, scriptData in ipairs(result.result.scripts) do
                    createScriptCard(scriptData)
                end
            else
                Nexus:Notify({
                    Title = "CONNECTION ERROR",
                    Description = "Unable to reach ScriptBlox network",
                    Type = "Pulse",
                    Duration = 4
                })
            end
        end)
    end
    
    -- Event Connections
    searchButton.MouseButton1Click:Connect(function()
        Quantum:Ripple(searchButton, UDim2.new(0.5, 0, 0.5, 0), Nexus.Palette.Core)
        performSearch(searchBox.Text)
    end)
    
    searchBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            performSearch(searchBox.Text)
        end
    end)
    
    closeBtn.MouseButton1Click:Connect(function()
        Quantum:Tween(container, {
            Size = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1
        }, 0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In, function()
            singularity:Destroy()
        end)
    end)
    
    -- Entrance animation
    container.Size = UDim2.new(0, 0, 0, 0)
    Quantum:Tween(container, {Size = UDim2.new(0, 900, 0, 600)}, 0.7, Enum.EasingStyle.Back)
    
    -- Auto focus
    searchBox:CaptureFocus()
    
    return singularity
end

