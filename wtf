        orbital.Visible = true
        orbital.Size = UDim2.new(0, 0, 0, 0)
        Quantum:Tween(orbital, {Size = UDim2.new(0, 60, 0, 60)}, 0.8, Enum.EasingStyle.Back)
    end)
    
